{
    "name": "workload-tracker-frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build && npm run check:fullcalendar-chunk && npm run check:ui-hardcoded",
        "build:analyze": "vite build && echo 'Bundle analysis generated at dist/stats.html'",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "lint:soft": "eslint . --ext ts,tsx --report-unused-disable-directives",
        "check:ui-hardcoded": "node scripts/check-ui-hardcoded.mjs",
        "check:ui-hardcoded:report": "node scripts/check-ui-hardcoded.mjs --report",
        "fix:ui-hardcoded": "node scripts/autofix-ui-hardcoded.mjs",
        "preview": "vite preview",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:run": "vitest run",
        "e2e": "playwright test",
        "e2e:api-call-budgets": "API_CALL_BUDGET_GATE=true API_CALL_BUDGET_MODE=production-build playwright test tests/e2e/api-call-budgets.spec.ts",
        "e2e:precanary": "playwright test tests/e2e/01_login.spec.ts tests/e2e/02_people.spec.ts tests/e2e/03_projects.spec.ts tests/e2e/assignments-mobile.spec.ts tests/e2e/project-assignments-mobile.spec.ts tests/e2e/departments-reports-accordion.spec.ts tests/e2e/role-capacity.spec.ts tests/e2e/team-forecast.spec.ts",
        "e2e:ui": "playwright test --ui",
        "e2e:codegen": "playwright codegen",
        "perf:probe:api-calls": "node scripts/probe-api-call-budgets.mjs --mode=production --output tests/perf/latest.json",
        "perf:assert:api-calls": "node scripts/assert-api-call-budgets.mjs --budgets tests/perf/api-call-budgets.json --actual tests/perf/latest.json",
        "perf:check:api-calls": "npm run perf:probe:api-calls && npm run perf:assert:api-calls",
        "openapi:types": "openapi-typescript ../backend/openapi.json -o src/api/schema.ts",
        "openapi:regen": "npm run openapi:types",
        "check:health": "node scripts/check-file-health.mjs",
        "check:health:projects": "node scripts/check-file-health-projects.mjs",
        "check:line-caps:work-planning": "node scripts/check-page-line-caps.mjs",
        "prepare": "husky install",
        "check:fullcalendar-chunk": "node scripts/check-fullcalendar-chunk.mjs"
    },
    "overrides": {
        "esbuild": "0.25.9",
        "qs": "6.14.1",
        "body-parser": "1.20.4",
        "express": "4.22.1",
        "tar-fs": "3.1.1",
        "glob": "10.5.0",
        "js-yaml": "4.1.1",
        "markdown-it": "14.1.1",
        "undici": "7.22.0",
        "lodash": "4.17.23",
        "lodash-es": "4.17.23"
    },
    "dependencies": {
        "@dnd-kit/core": "6.3.1",
        "@dnd-kit/sortable": "10.0.0",
        "@dnd-kit/utilities": "3.2.2",
        "@fullcalendar/core": "^6.1.20",
        "@fullcalendar/daygrid": "^6.1.20",
        "@fullcalendar/list": "^6.1.20",
        "@fullcalendar/react": "^6.1.20",
        "@fullcalendar/timegrid": "^6.1.20",
        "@sentry/react": "10.8.0",
        "@sentry/vite-plugin": "4.2.0",
        "@tanstack/react-query": "5.59.0",
        "@tanstack/react-query-devtools": "5.59.0",
        "@tanstack/react-virtual": "3.13.12",
        "@tiptap/extension-link": "2.27.1",
        "@tiptap/extension-placeholder": "2.27.1",
        "@tiptap/extension-text-align": "2.27.1",
        "@tiptap/extension-underline": "2.27.1",
        "@tiptap/pm": "2.7.0",
        "@tiptap/react": "2.27.1",
        "@tiptap/starter-kit": "2.27.1",
        "clsx": "2.1.1",
        "dompurify": "3.3.1",
        "graphology": "^0.26.0",
        "graphology-layout-forceatlas2": "^0.10.1",
        "graphology-layout-noverlap": "^0.4.2",
        "openapi-fetch": "0.9.2",
        "react": "19.1.1",
        "react-dom": "19.1.1",
        "react-grid-layout": "^2.2.2",
        "react-resizable": "^3.1.3",
        "react-router": "7.12.0",
        "serve": "14.2.5",
        "sigma": "^3.0.2",
        "web-vitals": "5.1.0"
    },
    "devDependencies": {
        "@lhci/cli": "0.15.1",
        "@playwright/test": "1.57.0",
        "@testing-library/jest-dom": "6.6.2",
        "@testing-library/react": "16.3.0",
        "@testing-library/user-event": "14.5.2",
        "@types/react": "19.1.13",
        "@types/react-dom": "19.1.9",
        "@typescript-eslint/eslint-plugin": "8.8.1",
        "@typescript-eslint/parser": "8.8.1",
        "@vitejs/plugin-react": "5.0.2",
        "autoprefixer": "10.4.21",
        "eslint": "9.35.0",
        "eslint-config-prettier": "9.1.0",
        "eslint-import-resolver-typescript": "3.6.1",
        "eslint-plugin-import-x": "4.2.1",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-react-refresh": "0.4.13",
        "husky": "9.1.7",
        "jsdom": "25.0.1",
        "lint-staged": "15.2.10",
        "msw": "2.4.9",
        "openapi-typescript": "7.13.0",
        "postcss": "8.5.6",
        "prettier": "3.3.3",
        "rollup-plugin-visualizer": "6.0.3",
        "tailwindcss": "3.4.13",
        "typescript": "5.9.2",
        "vite": "7.3.1",
        "vite-plugin-pwa": "1.0.3",
        "vitest": "3.2.4"
    },
    "lint-staged": {
        "src/pages/Projects/**/*.{ts,tsx}": [
            "prettier --write",
            "eslint --fix",
            "npm run -s check:health:projects"
        ],
        "src/components/projects/ProjectStatusDropdown.tsx": [
            "prettier --write",
            "eslint --fix",
            "npm run -s check:health:projects"
        ]
    }
}
