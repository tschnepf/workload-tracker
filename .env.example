# ============================================================
# Non-secret environment template
# ============================================================
# Copy this file to `.env`.
# Put sensitive values in `.env.secrets` (see `.env.secrets.example`).
#
# Important: many compose variables are interpolated before container start.
# If your compose runner only auto-loads `.env`, make sure secret values are
# also available there (or exported in shell) at runtime.

# === Project / Build ===
COMPOSE_PROJECT_NAME=workload-tracker
DOCKER_BUILDKIT=1
APP_NAME=workload-tracker

# === Runtime Mode ===
DEBUG=false
DJANGO_SETTINGS_MODULE=config.settings
RUN_MIGRATIONS_ON_START=true

# === Hosts / Origins ===
ALLOWED_HOSTS=smc-projects.com,www.smc-projects.com
CORS_ALLOWED_ORIGINS=https://smc-projects.com,https://www.smc-projects.com
CSRF_TRUSTED_ORIGINS=https://smc-projects.com,https://www.smc-projects.com
OAUTH_POPUP_ALLOWED_ORIGINS=https://smc-projects.com,https://www.smc-projects.com
# Optional: expose to another machine on the LAN
HOST_IP=

# === Ports / URLs ===
BACKEND_PORT=8000
FRONTEND_PORT=3000
API_BASE_URL=https://smc-projects.com/api
VITE_API_URL=/api
FRONTEND_API_URL=/api
APP_BASE_URL=https://smc-projects.com
EMAIL_DOMAIN=smc-projects.com

# === Database (non-secret) ===
POSTGRES_DB=workload_tracker_prod
POSTGRES_USER=workload_user
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SUPERUSER_RESERVED_CONNECTIONS=5
DB_SCHEMA=public
DB_WAIT_TIMEOUT_SECS=120
DB_WAIT_SLEEP_SECS=1

# === PgBouncer ===
PGBOUNCER_PORT=6432
PGBOUNCER_AUTH_TYPE=scram-sha-256
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1500
PGBOUNCER_DEFAULT_POOL_SIZE=60
PGBOUNCER_RESERVE_POOL_SIZE=20
PGBOUNCER_MAX_DB_CONNECTIONS=120
PGBOUNCER_IGNORE_STARTUP_PARAMETERS=extra_float_digits,options
PGBOUNCER_SERVER_RESET_QUERY=DISCARD ALL
PGBOUNCER_ADMIN_USERS=postgres

# === Cache / Performance / Scale ===
ASYNC_JOBS=true
CELERY_TASK_ALWAYS_EAGER=false
DB_CONN_MAX_AGE=0
DB_CONN_HEALTH_CHECKS=true
DISABLE_SERVER_SIDE_CURSORS=true
SHORT_TTL_AGGREGATES=true
CACHE_DEFAULT_TIMEOUT=300
AGGREGATE_CACHE_TTL=30
DASHBOARD_CACHE_TTL=30
DEPT_DESC_CACHE_TTL=300
SILK_ENABLED=false

# === Security / Auth Flags ===
AUTH_ENFORCED=true
COOKIE_REFRESH_AUTH=true
FRONTEND_COOKIE_REFRESH_AUTH=true
VITE_COOKIE_REFRESH_AUTH=true
PWA_ENABLED=true
WEB_PUSH_ENABLED=false
WEB_PUSH_ASSIGNMENT_EVENTS_ENABLED=true
WEB_PUSH_REMINDER_EVENTS_ENABLED=true
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:noreply@example.com
WEB_PUSH_TEST_STAFF_ONLY=true
LOGIN_PROTECTION=false
OPENAPI_PUBLIC=false
ADMIN_PASSWORD_RESET_SUPERUSER_ONLY=false
JOB_AUTHZ_WRITE_REQUIRED=false
JOB_AUTHZ_ENFORCED=false
JOB_RESTORE_TOKEN_MODE=true
FF_UI_BOOTSTRAP=true
FF_ASSIGNMENTS_AUTO_HOURS_BUNDLE=true
FF_ROLE_CAPACITY_TEMPLATE_ROLE_MAPPING=true
FF_PEOPLE_SKILLS_SETTINGS_SNAPSHOTS=true
FF_MODERATE_PAGES_SNAPSHOTS=true
RESTORE_JOB_TOKEN_TTL_SECONDS=300
JWT_ACCESS_MINUTES=120
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# === Login Protection (django-axes) ===
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1
AXES_NEVER_LOCKOUT_USERNAMES=
AXES_ALLOWED_CIDR_NETS=
AXES_ALERT_ADMINS=false

# === CSP ===
CSP_ENABLED=true
CSP_REPORT_ONLY=false
CSP_REPORT_URI=/csp-report/

# === Frontend UX Flags ===
VITE_OAUTH_MESSAGE_ORIGINS=
VITE_ROUTE_PREFETCH=true
VITE_VIEW_TRANSITIONS=false
VITE_PREFETCH_CONCURRENCY=2
VITE_NAV_PROGRESS=true
VITE_NAV_PENDING_OVERLAY=true
VITE_FF_UI_BOOTSTRAP=true
VITE_FF_ASSIGNMENTS_AUTO_HOURS_BUNDLE=true
VITE_FF_PEOPLE_SKILLS_SETTINGS_SNAPSHOTS=true
VITE_FF_MODERATE_PAGES_SNAPSHOTS=true
VITE_PWA_ENABLED=true

# === Sentry Metadata (non-secret) ===
SENTRY_UPLOAD=false
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
VITE_APP_VERSION=dev

# === DRF Throttles ===
DRF_THROTTLE_HEATMAP=1200/min
DRF_THROTTLE_SKILL_MATCH=600/min
DRF_THROTTLE_PROJECT_AVAILABILITY=600/min
DRF_THROTTLE_FIND_AVAILABLE=600/min
DRF_THROTTLE_GRID_SNAPSHOT=600/min
DRF_THROTTLE_UI_BOOTSTRAP=120/min
DRF_THROTTLE_SNAPSHOTS=120/min
DRF_THROTTLE_TOKEN_OBTAIN=120/min
DRF_THROTTLE_TOKEN_REFRESH=600/min
DRF_THROTTLE_BACKUP_CREATE=2/hour
DRF_THROTTLE_BACKUP_DELETE=5/hour
DRF_THROTTLE_BACKUP_DOWNLOAD=20/hour
DRF_THROTTLE_BACKUP_STATUS=120/min
# DRF_THROTTLE_BACKUP_RESTORE=2/hour
# DRF_THROTTLE_BACKUP_UPLOAD_RESTORE=2/hour

# === Backup / Retention ===
BACKUPS_DIR=/backups
READ_ONLY_MODE=false
BACKUP_UPLOAD_MAX_BYTES=5368709120
BACKUP_ENCRYPTION_ENABLED=false
BACKUP_ENCRYPTION_PROVIDER=gpg
BACKUP_ENCRYPTION_RECIPIENT=
BACKUP_OFFSITE_ENABLED=false
BACKUP_OFFSITE_PROVIDER=
BACKUP_OFFSITE_BUCKET=
BACKUP_OFFSITE_PREFIX=
ENABLE_AUTOMATION=false
BACKUP_SCHEDULE_CRON=0 2 * * *
CLEANUP_SCHEDULE_CRON=30 2 * * *
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12
ROLLUP_REBUILD_SCHEDULE_CRON=0 4 * * *
RESTORE_TEST_ENABLED=false
# RESTORE_TEST_SCHEDULE_CRON=0 4 * * *

# === Worker / Celery paths ===
CELERY_BEAT_SCHEDULE_FILE=/tmp/celery/beat-schedule
CELERY_BEAT_DIR=

# === Risk Attachments ===
RISK_ATTACHMENTS_DIR=/app/risk_attachments
# RISK_UPLOAD_MAX_BYTES=104857600

# === Integrations (non-secret) ===
INTEGRATIONS_ENABLED=false
BQE_AUTH_BASE_URL=https://api-identity.bqecore.com/idp/connect
BQE_SCOPES="readwrite:core offline_access openid email profile"
BQE_COMPANY_ID=
BQE_REDIRECT_URI=https://smc-projects.com/api/integrations/bqe/connect/callback

# === Email (non-secret SMTP settings) ===
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Workload Tracker <noreply@smc-projects.com>
SERVER_EMAIL=noreply@smc-projects.com
EMAIL_TIMEOUT=10

# === Dev convenience ===
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
AUTO_FIX_JWT_BLACKLIST=true
