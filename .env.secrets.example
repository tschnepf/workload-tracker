# ============================================================
# Sensitive environment template
# ============================================================
# Copy to `.env.secrets` and fill in real secrets.
# Never commit `.env.secrets`.
#
# If your compose runner only auto-loads `.env`, you must also make these
# values available for interpolation (merge into `.env` or export before run).

# === Django / App secrets ===
SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY
RESTORE_JOB_TOKEN_SECRET=CHANGE_ME_RESTORE_JOB_TOKEN_SECRET

# === Database secrets ===
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Optional URL-style DB overrides (if you use a managed/external DB)
# DATABASE_URL=postgresql://workload_user:CHANGE_ME_POSTGRES_PASSWORD@db:5432/workload_tracker_prod
# DB_ADMIN_URL=postgresql://workload_user:CHANGE_ME_POSTGRES_PASSWORD@db:5432/workload_tracker_prod

# === Redis secrets ===
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# === Observability / notifications ===
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# === Integrations secrets ===
INTEGRATIONS_SECRET_KEY=
BQE_CLIENT_ID=
BQE_CLIENT_SECRET=

# === Email account credentials ===
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# === Frontend release tooling secrets (optional) ===
VITE_SENTRY_AUTH_TOKEN=

# === Optional dev-only secret ===
DJANGO_SUPERUSER_PASSWORD=
